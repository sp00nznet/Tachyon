<?xml version="1.0" encoding="utf-8"?>
<ship_data>
    <!--
        FTL's XML files don't list the achievements for each ship, so instead
        of hardcoding them into XFTL as well, they're listed here.

        Note the unlockId property corresponds to the ID passed to the
        <unlockShip> element in events. Note that while this is always an
        integer in vanilla, it can be anything here.

        hasQuest (a boolean) sets whether the exclamation mark appears in
        the pause menu and hangar to show the unlock quest. It's automatically
        set to true when the unlockId attribute is present, but can be used
        to disable the mark for a ship that shouldn't show it.
    -->

    <ship_family>
        <ship id="PLAYER_SHIP_HARD"/>
        <ship id="PLAYER_SHIP_HARD_2"/>
        <ship id="PLAYER_SHIP_HARD_3"/>

